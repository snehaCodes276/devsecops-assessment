# Python
sudo apt install python3 python3-venv python3-pip -y

# Node (latest)
curl -fsSL https://deb.nodesource.com/setup_20.x | sudo bash -
sudo apt install nodejs -y

# Java (required for sonar)
sudo apt install openjdk-17-jdk -y

# Sonar Scanner
cd /opt
sudo wget https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-5.0.1.3006-linux.zip
sudo unzip sonar-scanner*.zip
sudo mv sonar-scanner* sonar-scanner
echo 'export PATH=$PATH:/opt/sonar-scanner/bin' >> ~/.bashrc

# OWASP Dependency Check
cd /opt
sudo unzip dependency-check-9.0.9-release.zip -o
echo 'export PATH=$PATH:/opt/dependency-check/bin' >> ~/.bashrc

# kubectl
curl -LO https://storage.googleapis.com/kubernetes-release/release/$(curl -s https://storage.googleapis.com/kubernetes-release/release/stable.txt)/bin/linux/amd64/kubectl
chmod +x kubectl
sudo mv kubectl /usr/local/bin/

# kube-linter (FIXED)
curl -LO https://github.com/stackrox/kube-linter/releases/latest/download/kube-linter-linux
chmod +x kube-linter-linux
sudo mv kube-linter-linux /usr/local/bin/kube-linter
