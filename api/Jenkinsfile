pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        APP_NAME = 'api'
        IMAGE_TAG = "${BUILD_NUMBER}"

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-dev"
        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-prod"

        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout Code') {
            steps { checkout scm }
        }

        stage('Setup Python') {
            steps {
                sh '''
                if [ -f requirements.txt ]; then
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                else
                    echo "No requirements.txt found"
                fi
                '''
            }
        }

        stage('Static Analysis') {
            parallel {
                stage('SonarQube') {
                    steps {
                        withSonarQubeEnv('sonarqube') {
                            sh 'sonar-scanner -Dsonar.projectKey=api -Dsonar.sources=api'
                        }
                    }
                }

                stage('OWASP') {
                    steps {
                        sh '''
                        if [ -d /opt/dependency-check/bin ]; then
                            /opt/dependency-check/bin/dependency-check.sh --project api --scan . --out .
                        else
                            echo "OWASP tool not installed"
                        fi
                        '''
                    }
                }
            }
        }

        stage('Tests') {
            steps {
                sh 'pytest || true'
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                if [ -f api/Dockerfile ]; then
                    docker build -t api:${BUILD_NUMBER} ./api
                else
                    echo "Dockerfile missing in api/"
                    exit 1
                fi
                '''
            }
        }

        stage('Verify Image') {
            steps {
                sh 'docker images | grep api'
            }
        }

        stage('Security Scan') {
            steps {
                sh 'grype api:${BUILD_NUMBER} || true'
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    REPO=${ECR_DEV}
                    if [ "$BRANCH_NAME" = "master" ]; then
                        REPO=${ECR_PROD}
                    fi

                    docker tag api:${BUILD_NUMBER} ${REPO}:${BUILD_NUMBER}
                    docker push ${REPO}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Helm Lint') {
            steps {
                sh '''
                rm -rf application-helm-charts
                git clone ${HELM_REPO}
                kube-linter lint application-helm-charts/application-helm-charts/api || true
                '''
            }
        }

        stage('EKS Check') {
            steps {
                sh 'kubectl get nodes'
            }
        }
    }
}
