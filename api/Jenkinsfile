pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        IMAGE_NAME = 'api'
        IMAGE_TAG = "${BUILD_NUMBER}"

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-dev"
        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-prod"

        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Setup Python Env') {
            steps {
                sh '''
                python3 -m venv venv || true
                . venv/bin/activate
                pip install -r requirements.txt || echo "Skipping pip install"
                '''
            }
        }

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Static Analysis') {
            parallel {

                stage('Sonar') {
                    steps {
                        withSonarQubeEnv('sonarqube') {
                            sh 'sonar-scanner -Dsonar.projectKey=api -Dsonar.sources=. || true'
                        }
                    }
                }

                stage('OWASP') {
                    steps {
                        sh 'dependency-check.sh --project api --scan . --out . || true'
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    try {
                        waitForQualityGate abortPipeline: false
                    } catch (err) {
                        echo "Skipping QG"
                    }
                }
            }
        }

        stage('Tests') {
            steps {
                sh 'pytest || echo "No tests"'
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                if [ -f Dockerfile ]; then
                  docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                else
                  echo "No Dockerfile"
                fi
                '''
            }
        }

        stage('Scan') {
            steps {
                sh 'grype ${IMAGE_NAME}:${IMAGE_TAG} -o json > scan.json || true'
            }
        }

        stage('Push ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    REPO=${ECR_DEV}
                    [ "$BRANCH_NAME" = "master" ] && REPO=${ECR_PROD}

                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${REPO}:${IMAGE_TAG}
                    docker push ${REPO}:${IMAGE_TAG} || true
                    '''
                }
            }
        }

        stage('Helm Lint') {
            steps {
                sh '''
                git clone ${HELM_REPO} || true
                kube-linter lint application-helm-charts/application-helm-charts/api || true
                '''
            }
        }

        stage('Check EKS') {
            steps {
                sh 'kubectl get nodes || echo "Cluster not connected"'
            }
        }
    }
}
