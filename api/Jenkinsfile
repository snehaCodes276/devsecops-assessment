pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-dev"

        IMAGE_TAG = "${BUILD_NUMBER}"
        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Clean') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                pip3 install -r requirements.txt || true
                '''
            }
        }

        stage('Tests') {
            steps {
                sh 'pytest || true'
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                    /opt/sonar-scanner/bin/sonar-scanner \
                      -Dsonar.projectKey=api-dev \
                      -Dsonar.sources=. || true
                    '''
                }
            }
        }

        stage('OWASP Scan') {
            steps {
                sh '''
                if [ -d /opt/dependency-check/bin ]; then
                    /opt/dependency-check/bin/dependency-check.sh \
                    --project api-dev --scan . --out .
                else
                    echo "OWASP not installed"
                fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build -t api:${BUILD_NUMBER} .
                '''
            }
        }

        stage('Verify Image') {
            steps {
                sh 'docker images | grep api || true'
            }
        }

        stage('Security Scan') {
            steps {
                sh 'grype api:${BUILD_NUMBER} || true'
            }
        }

        stage('Push to ECR (DEV)') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker tag api:${BUILD_NUMBER} ${ECR_DEV}:${BUILD_NUMBER}
                    docker push ${ECR_DEV}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Helm Check') {
            steps {
                sh '''
                rm -rf application-helm-charts || true
                git clone ${HELM_REPO}
                kube-linter lint application-helm-charts/application-helm-charts/api || true
                '''
            }
        }

        stage('EKS Check') {
            steps {
                sh '''
                kubectl get nodes || true
                kubectl get pods -n dev || true
                kubectl get svc -n dev || true
                '''
            }
        }
    }
}
