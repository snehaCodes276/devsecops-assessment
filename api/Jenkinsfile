pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        APP_NAME = 'api'
        IMAGE_TAG = "${BUILD_NUMBER}"

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-dev"
        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-prod"

        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout Code') {
            steps { checkout scm }
        }

        stage('Setup Python') {
            steps {
                sh '''
                if [ -f requirements.txt ]; then
                    python3 -m venv venv || true
                    . venv/bin/activate
                    pip install -r requirements.txt || true
                else
                    echo "No requirements.txt found"
                fi
                '''
            }
        }

        stage('Static Analysis') {
            parallel {

                stage('SonarQube') {
                    steps {
                        withSonarQubeEnv('sonarqube') {
                            sh 'sonar-scanner -Dsonar.projectKey=api -Dsonar.sources=. || true'
                        }
                    }
                }

                stage('OWASP') {
                    steps {
                        sh '/opt/dependency-check/bin/dependency-check.sh --project api --scan . --out . || true'
                    }
                }
            }
        }

        stage('Tests') {
            steps {
                sh 'pytest || true'
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                if [ -f Dockerfile ]; then
                    docker build -t api:${BUILD_NUMBER} .
                else
                    echo "Dockerfile missing"
                fi
                '''
            }
        }

        stage('Verify Image') {
            steps {
                sh 'docker images | grep api || true'
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                if docker images | grep api:${BUILD_NUMBER}; then
                    grype api:${BUILD_NUMBER} || true
                fi
                '''
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    REPO=${ECR_DEV}
                    if [ "$BRANCH_NAME" = "master" ]; then
                        REPO=${ECR_PROD}
                    fi

                    if docker images | grep api:${BUILD_NUMBER}; then
                        docker tag api:${BUILD_NUMBER} ${REPO}:${BUILD_NUMBER}
                        docker push ${REPO}:${BUILD_NUMBER}
                    else
                        echo "No image to push"
                    fi
                    '''
                }
            }
        }

        stage('Helm Lint') {
            steps {
                sh '''
                rm -rf application-helm-charts || true
                git clone ${HELM_REPO} || true
                kube-linter lint application-helm-charts/application-helm-charts/api || true
                '''
            }
        }

        stage('EKS Check') {
            steps {
                sh 'kubectl get nodes || true'
            }
        }
    }
}
