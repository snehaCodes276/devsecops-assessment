pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        APP_NAME = 'api'
        IMAGE_TAG = "${BUILD_NUMBER}"

        ECR_REPO = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/api-dev"

        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Setup Virtual Environment') {
            steps {
                sh '''
                python3 -m venv venv
                . venv/bin/activate
                pip install --upgrade pip

                if [ -f requirements.txt ]; then
                    pip install -r requirements.txt
                else
                    echo "requirements.txt not found"
                fi
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                . venv/bin/activate
                pytest -v || true
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                    sonar-scanner \
                      -Dsonar.projectKey=api-dev \
                      -Dsonar.sources=. \
                      -Dsonar.python.version=3
                    '''
                }
            }
        }

        stage('OWASP Scan') {
            steps {
                sh '''
                if [ -d /opt/dependency-check/bin ]; then
                    /opt/dependency-check/bin/dependency-check.sh \
                    --project api-dev --scan . --out .
                else
                    echo "OWASP not installed"
                fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build -t api:${BUILD_NUMBER} .
                '''
            }
        }

        stage('Verify Image') {
            steps {
                sh '''
                docker images | grep api || true
                '''
            }
        }

        stage('Security Scan (Grype)') {
            steps {
                sh '''
                grype api:${BUILD_NUMBER} || true
                '''
            }
        }

        stage('Push to ECR (DEV ONLY)') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker tag api:${BUILD_NUMBER} ${ECR_REPO}:${BUILD_NUMBER}
                    docker push ${ECR_REPO}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Helm Lint') {
            steps {
                sh '''
                rm -rf application-helm-charts || true
                git clone ${HELM_REPO}
                kube-linter lint application-helm-charts/application-helm-charts/api || true
                '''
            }
        }

        stage('EKS Check') {
            steps {
                sh '''
                kubectl get nodes || true
                kubectl get pods -n dev || true
                kubectl get svc -n dev || true
                '''
            }
        }
    }
}
