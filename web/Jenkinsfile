pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-dev"
        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-prod"

        IMAGE_TAG = "${BUILD_NUMBER}"
        APP_DIR = 'web'
    }

    options {
        timestamps()
    }

    stages {

        stage('Clean') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Structure') {
            steps {
                sh '''
                echo "Workspace contents:"
                ls -la
                echo "App directory contents:"
                ls -la ${APP_DIR}
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npm install'
                }
            }
        }

    stage('Tests') {
    steps {
        dir("${APP_DIR}") {
            sh '''
            TEST_SCRIPT=$(npm pkg get scripts.test)

            if [ "$TEST_SCRIPT" = "{}" ]; then
                echo "No test script found, skipping..."
            else
                echo "Running tests..."
                npm test
            fi
            '''
                          }
          }
                   }

       stage('SonarQube') {
    steps {
        withSonarQubeEnv('sonarqube') {
            sh '''
            /opt/sonar-scanner/bin/sonar-scanner \
              -Dsonar.projectKey=web \
              -Dsonar.sources=.
            '''
                                      }
          }
                          }

        // Disabled OWASP cleanly
        stage('OWASP Scan') {
            when {
                expression { return false }
            }
            steps {
                dir("${APP_DIR}") {
                    sh '''
                    /opt/dependency-check/bin/dependency-check.sh \
                    --project web --scan . --out . || true
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                    docker build -t web:${IMAGE_TAG} .
                    '''
                }
            }
        }

       stage('Push to ECR') {
    steps {
        withCredentials([usernamePassword(
            credentialsId: 'aws-creds',
            usernameVariable: 'AWS_ACCESS_KEY_ID',
            passwordVariable: 'AWS_SECRET_ACCESS_KEY'
        )]) {
            sh '''
            export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
            export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

            aws ecr get-login-password --region ${AWS_REGION} | \
            docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

            docker tag web:${IMAGE_TAG} ${ECR_DEV}:${IMAGE_TAG}
            docker push ${ECR_DEV}:${IMAGE_TAG}
            '''
            }
          }
                          }

       
    }

    post {
        success {
            echo "✅ Build completed successfully"
        }
        failure {
            echo "❌ Build failed - check logs"
        }
    }
}
