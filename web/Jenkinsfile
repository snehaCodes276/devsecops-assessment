pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        APP_NAME = 'web'
        IMAGE_TAG = "${BUILD_NUMBER}"

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-dev"
        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-prod"

        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout Code') {
            steps { checkout scm }
        }

        stage('Verify Tools') {
            steps {
                sh '''
                echo "Checking tools..."
                docker --version || true
                node -v || true
                npm -v || true
                sonar-scanner -v || true
                kubectl version --client || true
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                if [ -f package.json ]; then
                    npm install || true
                else
                    echo "No package.json found - skipping npm"
                fi
                '''
            }
        }

        stage('Static Analysis') {
            parallel {

                stage('SonarQube') {
                    steps {
                        withSonarQubeEnv('sonarqube') {
                            sh 'sonar-scanner -Dsonar.projectKey=web -Dsonar.sources=. || true'
                        }
                    }
                }

                stage('OWASP') {
                    steps {
                        sh '/opt/dependency-check/bin/dependency-check.sh --project web --scan . --out . || true'
                    }
                }
            }
        }

        stage('Tests') {
            steps {
                sh '''
                if [ -f package.json ]; then
                    npm test || true
                else
                    echo "No tests found"
                fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    sh '''
                    if [ -f Dockerfile ]; then
                        docker build -t web:${BUILD_NUMBER} .
                    else
                        echo "Dockerfile missing - skipping build"
                    fi
                    '''
                }
            }
        }

        stage('Verify Docker Image') {
            steps {
                sh '''
                docker images | grep web || echo "No image built"
                '''
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                if docker images | grep web:${BUILD_NUMBER}; then
                    grype web:${BUILD_NUMBER} || true
                else
                    echo "Skipping scan - image not found"
                fi
                '''
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    REPO=${ECR_DEV}
                    if [ "$BRANCH_NAME" = "master" ]; then
                        REPO=${ECR_PROD}
                    fi

                    if docker images | grep web:${BUILD_NUMBER}; then
                        docker tag web:${BUILD_NUMBER} ${REPO}:${BUILD_NUMBER}
                        docker push ${REPO}:${BUILD_NUMBER}
                    else
                        echo "No image to push"
                    fi
                    '''
                }
            }
        }

        stage('Helm Check') {
            steps {
                sh '''
                rm -rf application-helm-charts || true
                git clone ${HELM_REPO} || true
                kube-linter lint application-helm-charts/application-helm-charts/web || true
                '''
            }
        }

        stage('EKS Check') {
            steps {
                sh 'kubectl get nodes || true'
            }
        }
    }
}
