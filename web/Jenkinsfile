pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        // ONLY DEV for develop branch
        ECR_REPO = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-dev"

        IMAGE_TAG = "${BUILD_NUMBER}"
        APP_DIR = 'web'
    }

    options {
        timestamps()
    }

    stages {

        stage('Clean') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Structure') {
            steps {
                sh '''
                echo "Workspace structure:"
                ls -la

                echo "Web folder:"
                ls -la ${APP_DIR}
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npm install'
                }
            }
        }

        stage('Tests') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                    if npm run | grep -q "test"; then
                        npm test || true
                    else
                        echo "No test script found, skipping tests"
                    fi
                    '''
                }
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh """
                    /opt/sonar-scanner/bin/sonar-scanner \
                      -Dsonar.projectKey=web-dev \
                      -Dsonar.sources=${APP_DIR}
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${APP_DIR}") {
                    sh """
                    docker build -t web:${IMAGE_TAG} .
                    """
                }
            }
        }

        stage('Push to ECR (DEV ONLY)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'aws-creds',
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    sh """
                    export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
                    export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker tag web:${IMAGE_TAG} ${ECR_REPO}:${IMAGE_TAG}
                    docker push ${ECR_REPO}:${IMAGE_TAG}
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ WEB DEV pipeline successful"
        }
        failure {
            echo "❌ WEB DEV pipeline failed"
        }
    }
}
