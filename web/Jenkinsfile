pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-prod"

        IMAGE_TAG = "${BUILD_NUMBER}"
        APP_DIR = 'web'

        EKS_CLUSTER = 'your-eks-cluster-name'
        K8S_DEPLOYMENT = 'web-prod'
    }

    options {
        timestamps()
    }

    stages {

        stage('Clean') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Structure') {
            steps {
                sh '''
                echo "Workspace:"
                ls -la

                echo "Web folder:"
                ls -la ${APP_DIR}
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npm install || true'
                }
            }
        }

        stage('Tests') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                    if npm run | grep -q test; then
                        npm test || true
                    else
                        echo "No tests found"
                    fi
                    '''
                }
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh """
                    /opt/sonar-scanner/bin/sonar-scanner \
                      -Dsonar.projectKey=web-prod \
                      -Dsonar.sources=${APP_DIR}
                    """
                }
            }
        }

        stage('OWASP Scan') {
            steps {
                sh '''
                if [ -d /opt/dependency-check/bin ]; then
                    /opt/dependency-check/bin/dependency-check.sh \
                    --project web-prod --scan ${APP_DIR} --out . || true
                else
                    echo "OWASP not installed"
                fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                dir("${APP_DIR}") {
                    sh """
                    docker build -t web:${IMAGE_TAG} .
                    """
                }
            }
        }

        stage('Push to ECR (PROD)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'aws-creds',
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    sh """
                    export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
                    export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker tag web:${IMAGE_TAG} ${ECR_PROD}:${IMAGE_TAG}
                    docker push ${ECR_PROD}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Deploy to EKS (PROD)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'aws-creds',
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    sh """
                    export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
                    export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

                    aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}

                    kubectl set image deployment/${K8S_DEPLOYMENT} \
                    web=${ECR_PROD}:${IMAGE_TAG} -n default
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ WEB MASTER DEPLOYED TO EKS (PROD)"
        }
        failure {
            echo "❌ WEB MASTER PIPELINE FAILED"
        }
    }
}
