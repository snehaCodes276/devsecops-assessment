pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-dev"
        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-prod"

        IMAGE_TAG = "${BUILD_NUMBER}"
        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Clean') {
            steps { cleanWs() }
        }

        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                npm install
                '''
            }
        }

        stage('Tests') {
            steps {
                sh 'npm test || true'
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                    sonar-scanner \
                    -Dsonar.projectKey=web \
                    -Dsonar.sources=.
                    '''
                }
            }
        }

        stage('OWASP Scan') {
            steps {
                sh '''
                if [ -d /opt/dependency-check/bin ]; then
                    /opt/dependency-check/bin/dependency-check.sh \
                    --project web --scan . --out .
                else
                    echo "OWASP not installed"
                fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build -t web:${BUILD_NUMBER} .
                '''
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker tag web:${BUILD_NUMBER} ${ECR_DEV}:${BUILD_NUMBER}
                    docker push ${ECR_DEV}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('EKS Check') {
            steps {
                sh 'kubectl get nodes'
            }
        }
    }
}
