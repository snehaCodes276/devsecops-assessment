pipeline {
    agent { label 'slave' }

    environment {
        AWS_REGION = 'ap-south-1'
        ACCOUNT_ID = '475790160792'

        IMAGE_NAME = 'web'
        IMAGE_TAG = "${BUILD_NUMBER}"

        ECR_DEV = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-dev"
        ECR_PROD = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/web-prod"

        HELM_REPO = 'https://github.com/snehaCodes276/application-helm-charts.git'
    }

    stages {

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout Code') {
            steps { checkout scm }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                npm install || true
                '''
            }
        }

        stage('Static Analysis') {
            parallel {

                stage('SonarQube') {
                    steps {
                        withSonarQubeEnv('sonarqube') {
                            sh '''
                            sonar-scanner \
                            -Dsonar.projectKey=web \
                            -Dsonar.sources=.
                            '''
                        }
                    }
                }

                stage('OWASP') {
                    steps {
                        sh '''
                        dependency-check.sh \
                        --project web \
                        --scan . \
                        --format XML \
                        --out . || true
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Run Tests') {
            steps {
                sh 'npm test || echo "No tests"'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                if [ -f Dockerfile ]; then
                  docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                else
                  echo "Dockerfile not found, skipping"
                fi
                '''
            }
        }

        stage('Grype Scan') {
            steps {
                sh '''
                grype ${IMAGE_NAME}:${IMAGE_TAG} -o json > scan.json || true
                '''
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh '''
                    aws ecr get-login-password --region ${AWS_REGION} \
                    | docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    if [ "$BRANCH_NAME" = "master" ]; then
                        REPO=${ECR_PROD}
                    else
                        REPO=${ECR_DEV}
                    fi

                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${REPO}:${IMAGE_TAG}
                    docker push ${REPO}:${IMAGE_TAG}
                    '''
                }
            }
        }

        stage('Kubelinter') {
            steps {
                sh '''
                git clone ${HELM_REPO} || true
                kube-linter lint application-helm-charts/application-helm-charts/web || true
                '''
            }
        }

        stage('Check Cluster') {
            steps {
                sh '''
                kubectl get nodes || echo "Cluster not ready"
                '''
            }
        }
    }
}
